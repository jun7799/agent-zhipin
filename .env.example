# 数据库（初期用SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data/agent_zhipin.db
# PostgreSQL后期迁移: postgresql+asyncpg://user:pass@localhost:5432/agent_zhipin

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# 应用配置
APP_NAME=Agent直聘
APP_VERSION=1.0.0
DEBUG=true

# 限流配置
RATE_LIMIT_ANONYMOUS=5
RATE_LIMIT_REGISTERED=10
RATE_LIMIT_MEMBER=100

# 岗位配置
FREE_JOB_SLOTS=6
JOB_PRICE_CENTS=100
MEMBER_PRICE_CENTS=990
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=50

# 支付宝支付
ALIPAY_APP_ID=your_app_id
ALIPAY_APP_PRIVATE_KEY_PATH=keys/app_private_key.txt
ALIPAY_PUBLIC_KEY_PATH=keys/alipay_public_key.txt
ALIPAY_DEBUG=true
ALIPAY_NOTIFY_URL=https://your-domain/v1/payment/alipay/notify
ALIPAY_RETURN_URL=https://your-domain/payment/return
